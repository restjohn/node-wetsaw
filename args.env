WETSAW_BBOX="-76.94 38.94 -76.8199 39.01"
WETSAW_ZOOM_MIN=10
WETSAW_ZOOM_MAX=18
WETSAW_SCALE=2
WETSAW_STYLE=/wetsaw-data/styles/openstreetmap-carto/imagery-labels.xml
WETSAW_XSLT=/wetsaw-data/styles/postgis-params.xsl
WETSAW_XSLT_PARAM='["db.host:env.WETSAW_DB_HOST","db.port:env.WETSAW_DB_PORT","db.name:env.WETSAW_DB_NAME","db.user:env.WETSAW_DB_USER","db.password:env.WETSAW_DB_PASS"]'
WETSAW_DB_HOST=localhost # osmdb-stage-20181019.c5oj8a3sxhla.us-east-1.rds.amazonaws.com
WETSAW_DB_PORT=5432
WETSAW_DB_NAME=gis
WETSAW_DB_USER=postgres
WETSAW_DB_PASS=""
WETSAW_TABLE=wetsaw_tiles
WETSAW_TABLE_LABEL="Wetsaw Tiles"
WETSAW_TABLE_DESC="Built using Wetsaw"
WETSAW_GPKG="/wetsaw-data/out/${WETSAW_TABLE}.gpkg"
