{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Mocha Tests",
            "program": "${workspaceFolder}/node_modules/mocha/bin/_mocha",
            "args": [
                "-u",
                "tdd",
                "--timeout",
                "999999",
                "--colors",
                "${workspaceFolder}/test"
            ],
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Wetsaw Natural Earth Stylesheet",
            "program": "${workspaceFolder}/index.js",
            "cwd": "${workspaceFolder}/sample"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Wetsaw Labels Stylesheet",
            "program": "${workspaceFolder}/index.js",
            "args": ["--bbox", "-76.6915 39.2346 -76.5235 39.3593", "--table-label", "Wetsaw Test", "--table-desc", "Wetsaw Test: Baltimore area OSM tiles", "--scale", "2", "--zoom-min", "11", "--zoom-max", "12", "--style", "~/sandbox/openstreetmap-carto/openstreetmap-carto-local.xml"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Wetsaw XSLT Test",
            "program": "${workspaceFolder}/index.js",
            "env": {
                "WETSAW_GPKG": "./from_env.gpkg",
                "WETSAW_LOG_LEVEL": "DEBUG"
            },
            "console": "integratedTerminal",
            "args": [
                "--bbox", "-76.6915 39.2346 -76.5235 39.3593",
                "--table-label", "Wetsaw Test", "--table-desc", "Wetsaw Test: Baltimore area OSM tiles",
                "--scale", "2", "--zoom-min", "11", "--zoom-max", "12",
                "--style", "~/sandbox/openstreetmap-carto/openstreetmap-carto.xml",
                "--xslt", "./postgis-params.xsl",
                "--xslt-param", "db.host:localhost", "db.name:gis", "db.user:postgres"]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Wetsaw Env Params Test",
            "program": "${workspaceFolder}/index.js",
            "env": {
                "WETSAW_STYLE": "~/sandbox/openstreetmap-carto/openstreetmap-carto.xml",
                "WETSAW_XSLT": "./postgis-params.xsl",
                "WETSAW_XSLT_PARAM": "[\"db.host:localhost\", \"db.user:postgres\"]",
                "WETSAW_BBOX": "-76.6915 39.2346 -76.5235 39.3593",
                "WETSAW_ZOOM_MIN": "11",
                "WETSAW_ZOOM_MAX": "12",
                "WETSAW_TABLE": "env_params",
                "WETSAW_TABLE_LABEL": "Env Params",
                "WETSAW_TABLE_DESC": "Config from environment variables",
                "WETSAW_SCALE": "2",
                "WETSAW_GPKG": "./env_params.gpkg"
            },
            "args": []
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Error Event",
            "program": "${workspaceFolder}/err.js",
            "args": []
        },
        {
            "type": "node",
            "request": "attach",
            "name": "Attach Node Process",
            "processId": "${command:PickProcess}"
        }
    ]
}